# Resend – used to email contact form submissions to you and send a confirmation to the submitter.
# Get an API key at https://resend.com/api-keys
# Optional: set RESEND_FROM to a verified domain (e.g. "Ossman Harding Dental <hello@yourdomain.com>"). Defaults to onboarding@resend.dev for testing.
RESEND_API_KEY=

# Optional: for Office Locations map and footer map. Create a key at https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
