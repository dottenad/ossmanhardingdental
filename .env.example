# Resend – used to email quote/contact form submissions to you and send a confirmation to the submitter.
# Get an API key at https://resend.com/api-keys
# Optional: set RESEND_FROM to a verified domain (e.g. "Sound Custom Fences <hello@yourdomain.com>"). Defaults to onboarding@resend.dev for testing.
RESEND_API_KEY=

# Jobber API – optional; use if you want to also create jobs/requests in Jobber from the quote form.
# You do NOT need to build a public "Jobber app" for others to install. You only need API access for your own business:
# 1. Sign up at https://developer.getjobber.com/ and create an app (your own private app for Sound Custom Fences).
# 2. Use "Test in GraphiQL" in the Developer Center to get an access token, or complete OAuth with your Jobber account and use that token.
# 3. Put the token here. For long-lived use, implement OAuth refresh or regenerate the token in GraphiQL as needed.
JOBBER_ACCESS_TOKEN=

# Optional: Jobber API version (defaults to 2023-11-15). See https://developer.getjobber.com/docs/using_jobbers_api/api_versioning
# JOBBER_API_VERSION=2023-11-15

# Optional: for Service Areas map and footer map. Create a key at https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=